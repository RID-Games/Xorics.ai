<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <uses-permission android:name="android.permission.INTERNET" />

    <!-- G2 glasses raw BLE (base system). SCAN is neverForLocation: we scan for a
         named peripheral, not positioning. The legacy trio only installs on <= Android 11. -->
    <uses-permission
        android:name="android.permission.BLUETOOTH_SCAN"
        android:usesPermissionFlags="neverForLocation"
        tools:targetApi="s" />
    <uses-permission android:name="android.permission.BLUETOOTH_CONNECT" />
    <uses-permission android:name="android.permission.BLUETOOTH" android:maxSdkVersion="30" />
    <uses-permission android:name="android.permission.BLUETOOTH_ADMIN" android:maxSdkVersion="30" />
    <uses-permission android:name="android.permission.ACCESS_FINE_LOCATION" android:maxSdkVersion="30" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_CONNECTED_DEVICE" />
    <uses-permission android:name="android.permission.RECORD_AUDIO" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_MICROPHONE" />
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />
    <uses-permission android:name="android.permission.WAKE_LOCK" />
    <uses-permission android:name="android.permission.REQUEST_IGNORE_BATTERY_OPTIMIZATIONS" />
    <uses-permission android:name="android.permission.VIBRATE" />

    <application
        android:allowBackup="true"
        android:icon="@android:drawable/sym_def_app_icon"
        android:label="@string/app_name"
        android:supportsRtl="true"
        android:theme="@style/Theme.Xorics">

        <!-- Chat is the front door now. -->
        <activity
            android:name=".ChatActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- The voice/diagnostics control panel, opened from ChatActivity's "Voice" action. -->
        <activity
            android:name=".MainActivity"
            android:exported="false" />

        <!-- File explorer, opened from ChatActivity's "Files" action. -->
        <activity
            android:name=".FilesActivity"
            android:exported="false" />

        <service
            android:name=".VoiceService"
            android:exported="false"
            android:foregroundServiceType="microphone" />

        <service
            android:name=".WakeService"
            android:exported="false"
            android:foregroundServiceType="microphone" />

        <!-- G2 base system: separate launcher icon ("Xorics G2") so testing needs zero
             edits to the existing activities. Remove once wired into the main UI. -->
        <activity
            android:name=".g2.GlassesActivity"
            android:exported="true"
            android:label="Xorics G2">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- Foreground home of the G2 BLE link + plugin bus client. -->
        <service
            android:name=".g2.GlassesService"
            android:exported="false"
            android:foregroundServiceType="connectedDevice" />

    </application>
</manifest>
